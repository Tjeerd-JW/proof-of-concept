<script src="/js/chart.js" defer></script>

{% comment %} Vind de maximale waardes in de arrays {% endcomment %}
{% assign maxX = 0 %}
{% assign maxY = 0 %}

{% for item in chartData %}
  {% if item[xValue] > maxX %}
    {% assign maxX = item[xValue] %}
  {% endif %}
  {% if item[yValue] > maxY %}
    {% assign maxY = item[yValue] %}
  {% endif %}
{% endfor %}

<h1>max topics {{ maxX }} & max messages {{ maxY }}</h1>
<section class="layout">
  <article class="container">
    <p>X: {{ xValue }}</p>
    <p>Y: {{ yValue }}</p>
    <div class="chart">
      {% for item in chartData %}
        {% assign splitURL = item.link | split: '/' %}
        {% assign catID = splitURL[5] %}
        {% assign x = item[xValue] %}
        {% assign y = item[yValue] %}
        {% assign xPosition = x | divided_by: maxX | times: 98 %}
        {% assign yPosition = y | divided_by: maxY | times: 98 %}

        <a
          href="/categorie/{{catID}}"
          title="{{item.title}}"
          class="point"
          style="left:{{xPosition}}%; bottom:{{yPosition}}%; --anchor-name:anchor-{{catID}};"
          interestfor="{{catID}}"
        ></a>
        <p class="chart-popover" id="{{catID}}" style="--anchor-name:anchor-{{catID}};" popover>Een preview voor {{ item.title }}</p>
      {% endfor %}

      <div class="extra-info">
        <h3>Categorie</h3>
        <p>messages</p>
        <p>topics</p>
        <p>messages per topic</p>
        <a href="#">Bekijken</a>
      </div>
    </div>
  </article>
</section>
